# Logistaas Ads Intelligence System — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# On Render: set each variable in the service's "Environment" tab (Dashboard → Service → Environment).

# ── Application ──────────────────────────────────────────────────────────────
# Used by: api/server.py, api/auth.py
# On Render: APP_ENV=production (enables secure cookies over HTTPS)
# Locally:   APP_ENV=development (disables secure flag so HTTP cookies work)
APP_ENV=production

# ── Advisor Mode ─────────────────────────────────────────────────────────────
# Used by: analysis/advisor.py
# Values: deterministic (default) | claude
# deterministic — reports are generated from structured data without an AI model.
# claude        — reports are generated by Claude API (requires ANTHROPIC_API_KEY).
ADVISOR_MODE=deterministic

# ── Internal Auth ─────────────────────────────────────────────────────────────
# Used by: api/auth.py (all authenticated endpoints)
#
# APP_SECRET_KEY — long random secret for signing session cookies.
#   Generate with: python -c "import secrets; print(secrets.token_hex(32))"
#   or:            openssl rand -hex 32
APP_SECRET_KEY=replace_with_long_random_secret

# AUTH_USERS_JSON — JSON array of internal users (no database required).
#   Generate password hashes with: python scripts/create_user_hash.py
#   Format:
#   [
#     {"username":"youssef","password_hash":"pbkdf2_sha256$...","role":"admin"},
#     {"username":"kareem","password_hash":"pbkdf2_sha256$...","role":"viewer"},
#     {"username":"mdr","password_hash":"pbkdf2_sha256$...","role":"mdr"}
#   ]
AUTH_USERS_JSON=[]

# ── API Protection (optional — for API-only run triggers) ─────────────────────
# Used by: api/server.py — POST /run/daily, /run/weekly, /run/monthly
# Dashboard users should use cookie-based login instead of this token.
# If not set, run endpoints still accept admin cookie sessions.
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=

# ── HubSpot CRM ──────────────────────────────────────────────────────────────
# Used by: connectors/hubspot_pull.py (all schedulers)
# Private app token — generate in HubSpot → Settings → Integrations → Private Apps
HUBSPOT_API_KEY=

# ── Windsor.ai ───────────────────────────────────────────────────────────────
# Used by: connectors/windsor_pull.py (all schedulers)
# API key and account ID from Windsor.ai dashboard
WINDSOR_API_KEY=
WINDSOR_ACCOUNT_ID=

# ── Anthropic Claude API (optional — only required when ADVISOR_MODE=claude) ──
# Used by: analysis/advisor.py only when ADVISOR_MODE=claude
# Model: claude-sonnet-4-6
# Leave blank when ADVISOR_MODE=deterministic (the default).
ANTHROPIC_API_KEY=

# ── Report delivery ──────────────────────────────────────────────────────────
# Used by: scheduler/delivery.py (weekly + monthly schedulers)
# SENDGRID_API_KEY       — SendGrid API key for outbound email
# REPORT_SENDER_EMAIL    — Verified sender address (must be authenticated in SendGrid)
# REPORT_RECIPIENT_EMAIL — Address that receives completed reports
SENDGRID_API_KEY=
REPORT_SENDER_EMAIL=
REPORT_RECIPIENT_EMAIL=youssef.awwad@logistaas.com

# ── Google Ads API ───────────────────────────────────────────────────────────
# Used by: connectors/oct_uploader.py (not yet built — leave blank until available)
# Required when OCT uploads are enabled.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=3059734490
